rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && userDocExists() &&
        getUserData().role == 'admin';
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && userDocExists() && getUserData().companyId == companyId;
    }

    // Users collection (root level)
    match /users/{userId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == userId ||
         (userDocExists() && getUserData().companyId == resource.data.companyId));

      allow create: if isAuthenticated() && request.auth.uid == userId;

      allow update: if (isAdmin() && userDocExists() && getUserData().companyId == resource.data.companyId) ||
        (isAuthenticated() && request.auth.uid == userId &&
          request.resource.data.role == resource.data.role);

      allow delete: if (isAdmin() && userDocExists() && getUserData().companyId == resource.data.companyId) ||
        (isAuthenticated() && request.auth.uid == userId);
    }

    // App metadata (e.g. first-user flag)
    match /metadata/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }

    // Notifications (created by Cloud Functions, read by recipients)
    match /notifications/{notifId} {
      allow read: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource.data.recipientUid == request.auth.uid;
      allow create: if false; // Only Cloud Functions can create
    }

    // Companies collection
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow create: if isAuthenticated();
      allow update: if belongsToCompany(companyId) && isAdmin();
      allow delete: if belongsToCompany(companyId) && isAdmin();

      // Products subcollection
      match /products/{productId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update: if belongsToCompany(companyId);
        allow delete: if belongsToCompany(companyId) && isAdmin();
      }

      // Categories subcollection
      match /categories/{categoryId} {
        allow read: if belongsToCompany(companyId);
        allow create, update, delete: if belongsToCompany(companyId);
      }

      // Transactions subcollection
      match /transactions/{transactionId} {
        allow read: if belongsToCompany(companyId);
        allow create: if belongsToCompany(companyId);
        allow update: if belongsToCompany(companyId) && isAdmin();
        allow delete: if belongsToCompany(companyId) && isAdmin();
      }

      // Vendors subcollection
      match /vendors/{vendorId} {
        allow read: if belongsToCompany(companyId);
        allow create, update: if belongsToCompany(companyId) && isAdmin();
        allow delete: if belongsToCompany(companyId) && isAdmin();
      }
    }
  }
}
