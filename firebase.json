{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/privacy-policy.html", "destination": "/privacy-policy.html" },
      { "source": "/terms.html", "destination": "/terms.html" },
      { "source": "/data-deletion.html", "destination": "/data-deletion.html" },
      { "source": "/support.html", "destination": "/support.html" },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
